# ============================================================
# IoMT CardioAI Backend — Environment Variables
# Copy to .env and populate before starting the service.
# NEVER commit .env to source control.
# ============================================================

# ── Required secrets (from Vault / AWS SSM / GCP Secret Manager) ────────────
IOMT_SHARED_SECRET=REPLACE_WITH_32_CHAR_SECRET_FROM_VAULT
IOMT_JWT_SECRET=REPLACE_WITH_32_CHAR_JWT_SECRET_FROM_VAULT

# ── Required identity ────────────────────────────────────────────────────────
IOMT_SERVER_WS_URL=wss://iomt.hospital.local/stream
CARDIOAI_BACKEND_ID=cardioai-prod-01

# ── Optional — IoMT server ───────────────────────────────────────────────────
IOMT_SERVER_REST_URL=https://iomt.hospital.local/api/v1
IOMT_SERVER_ID=IOMT-SRV-001

# ── Optional — WebSocket listener ────────────────────────────────────────────
CARDIOAI_WS_HOST=0.0.0.0
CARDIOAI_WS_PORT=8765
CARDIOAI_HEALTH_PORT=8080

# ── Optional — Security ──────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
TOKEN_TTL_SECONDS=3600

# ── Optional — Streaming ─────────────────────────────────────────────────────
RPM_POLL_INTERVAL_SEC=1.0
HEARTBEAT_INTERVAL_SEC=10.0
RECONNECT_MAX_ATTEMPTS=5
RECONNECT_BASE_DELAY_SEC=2.0
INBOUND_QUEUE_MAXSIZE=2000

# ── Optional — Observability ─────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
